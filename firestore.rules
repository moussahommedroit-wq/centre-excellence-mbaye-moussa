rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return signedIn() && profile().role == 'admin'; }
    function approved() { return signedIn() && (profile().status == 'approved' || isAdmin()); }
    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId && request.resource.data.role == 'student' && request.resource.data.status == 'pending' && request.resource.data.payment == 'pending';
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /announcements/{id} { allow read: if true; allow create, update, delete: if isAdmin(); }
    match /documents/{id} { allow read: if approved(); allow create, update, delete: if isAdmin(); }
  }
}
