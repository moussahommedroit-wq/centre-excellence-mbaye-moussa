rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && userDoc().data.role == 'admin'; }
    function isActiveMember() {
      return signedIn()
        && userDoc().data.role == 'member'
        && userDoc().data.active == true
        && (userDoc().data.expiresAt == null || userDoc().data.expiresAt > request.time);
    }
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /documents/{documentId} {
      allow read: if isAdmin() || isActiveMember();
      allow create, update, delete: if isAdmin();
    }
  }
}
